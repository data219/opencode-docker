// opencode-docker-config:1
// OpenAI ChatGPT subscription variant.
// Auth is handled by OpenCode's built-in OpenAI OAuth/device-login flow, not by OPENAI_API_KEY.
// This model map follows Oh My OpenAgent's OpenAI-only generator output.
// OmO upstream currently emits openai/gpt-5.4-mini-fast for explore/librarian, but the current
// OpenCode/models.dev catalog does not expose that model id, so gpt-5.4-mini-fast is substituted with openai/gpt-5.4-mini.
// Codex with a ChatGPT account rejects gpt-5.3-codex, so those category mappings use openai/gpt-5.4.
// GPT-5.3-Codex-Spark is available as a separate-rate-limit, low-latency coding model in ChatGPT/CLI preview.
{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ],
      "prompt_append": "Avoid long silent polling. Do not run sleeps longer than 30 seconds or multi-minute wait loops. For external review/CI waits, use bounded short polling with narrow JSON/JQ fields, persist pending state with the next exact poll command, and stop cleanly instead of calling it a harness interruption."
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ],
      "prompt_append": "Follow established plans precisely. Ask for clarification when plans are ambiguous. Prefer small, testable changes. Use LSP and AST-grep aggressively."
    },
    "prometheus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ],
      "prompt_append": "Always interview first. Validate scope before planning. Build exhaustive plans with milestones, risks, and contingencies. Max 2 parallel background tasks."
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ],
      "prompt_append": "Critically evaluate plans. Identify gaps, risks, and improvements. Be thorough."
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ],
      "prompt_append": "Challenge all assumptions in plans. Look for edge cases, failure modes, and overlooked requirements."
    },
    "atlas": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.3-codex-spark",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ],
      "variant": "medium"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "openai/gpt-5.3-codex-spark",
        "openai/gpt-5.5",
        "openai/gpt-5.4"
      ],
      "prompt_append": "Prefer searching official documentation and library sources over general web search."
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        "openai/gpt-5.3-codex-spark",
        "openai/gpt-5.4",
        "openai/gpt-5.5"
      ],
      "prompt_append": "Focus on finding authoritative sources. Cross-reference results when possible. Keep research brief and decision-oriented: return only the facts needed for the current task, cite sources, and avoid exhaustive result dumps or broad background unless explicitly requested. Prefer a short answer with 3-5 high-signal bullets over long summaries."
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark",
        "openai/gpt-5.5"
      ]
    }
  },
  "categories": {
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "visual-engineering": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "writing": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    },
    "quick": {
      "model": "openai/gpt-5.3-codex-spark",
      "fallback_models": [
        "openai/gpt-5.4-mini",
        "openai/gpt-5.4"
      ]
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "variant": "low",
      "fallback_models": [
        "openai/gpt-5.3-codex-spark",
        "openai/gpt-5.4"
      ]
    },
    "artistry": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "openai/gpt-5.4",
        "openai/gpt-5.4-mini",
        "openai/gpt-5.3-codex-spark"
      ]
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60
  },
  "default_mode": {
    "ultrawork": true,
    "ralph_loop": true
  },
  "background_task": {
    "staleTimeoutMs": 5400000,
    "messageStalenessTimeoutMs": 7200000,
    "taskTtlMs": 7200000,
    "sessionGoneTimeoutMs": 180000,
    "providerConcurrency": {
      "openai": 3
    },
    "modelConcurrency": {
      "openai/gpt-5.5": 2,
      "openai/gpt-5.4": 2,
      "openai/gpt-5.4-mini": 2,
      "openai/gpt-5.3-codex-spark": 3
    }
  },
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": false
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_"
  },
  "sisyphus_agent": {
    "planner_enabled": true,
    "replace_plan": true
  },
  "hashline_edit": true,
  "experimental": {
    "aggressive_truncation": false,
    "task_system": true,
    "auto_resume": true
  }
}
